# ============================================================
# Bambu2OBS – Example Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Bambu Cloud credentials ----
REGION=global
EMAIL=your@email.com
PASSWORD=your_password
BAMBU_CLOUD_TOKEN=

# ---- Printer connection ----
PRINTER_SN=your_printer_serial_number
PRINTER_IP=192.168.1.100
ACCESS_CODE=your_access_code

# ---- Data directory ----
# Folder where all overlay text files, images, and status data are written.
#
# IMPORTANT: During an active print, this folder is updated continuously
# (every few seconds via MQTT). Storing it inside a cloud-synced folder
# (OneDrive, Dropbox, Google Drive, etc.) is strongly discouraged -- it
# will cause constant sync churn, potential file-lock conflicts, and
# unnecessary network/CPU overhead for data that has no value being synced.
#
# RECOMMENDED: Point BASE_DIR to a local-only path such as Windows AppData,
# which requires no admin rights and is not synced by OneDrive by default:
#   BASE_DIR=C:\Users\YourName\AppData\Local\Bambu2OBS\data
#
# The folder can be placed anywhere that is convenient, but keep in mind:
#   1. The server process must have write access to the target folder.
#      Paths directly under C:\ (e.g. C:\MyData) require admin/elevated rights.
#      Paths inside your user profile (AppData, Documents, Desktop) do not.
#   2. The folder is created automatically on first run if it does not exist,
#      provided the parent path is accessible.
#   3. Absolute paths are used as-is; relative paths are resolved from the
#      repo root.
#
BASE_DIR=C:\Users\YourName\AppData\Local\Bambu2OBS\data

# ---- Debug / diagnostics ----
# Set to "true" to write raw MQTT messages to ConnectionDumps.json
DEBUG_DUMPS=false

# ---- OBS Auto-Kill (optional) ----
# When OBS_AUTO_KILL=true, Bambu2OBS will automatically stop the OBS stream
# and close OBS Studio 30 seconds after the print finishes (gcode_state=FINISH).
#
# OBS_WEBSOCKET_IP     – IP address of the machine running OBS.
#                        Use 127.0.0.1 if OBS is on the same machine as this server.
# OBS_WEBSOCKET_PORT   – OBS WebSocket server port (default: 4455).
# OBS_WEBSOCKET_PASSWORD – Password set in OBS → Tools → WebSocket Server Settings.
#                          Leave blank if authentication is disabled.
# OBS_AUTO_KILL        – Set to "true" to enable the feature (default: false).
# OBS_FINISH_DELAY     – Seconds to wait after print finishes before killing OBS (default: 30).

OBS_WEBSOCKET_IP=127.0.0.1
OBS_WEBSOCKET_PORT=4455
OBS_WEBSOCKET_PASSWORD=your_obs_websocket_password
OBS_AUTO_KILL=false
OBS_FINISH_DELAY=30

# ---- Idle server shutdown (optional) ----
# Bambu2OBS will automatically shut itself down (kill the server process) if
# no active print is detected within SERVER_IDLE_TIMEOUT minutes of starting.
#
# This covers two scenarios:
#   1. The server starts but the printer is idle — no print ever begins.
#   2. A print finishes and OBS is killed — no new print starts afterwards.
#
# In both cases the server exits cleanly after the timeout so it does not
# keep running indefinitely in the background.
#
# Set to 0 to disable the idle shutdown entirely.
# Default: 15 (minutes)
SERVER_IDLE_TIMEOUT=15
